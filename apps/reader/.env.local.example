# For develop features related to synchronization,
# you should register an app on Dropbox:
# https://www.dropbox.com/developers/apps/create
NEXT_PUBLIC_DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

NEXT_PUBLIC_BOOKSTORE_URL=http://localhost:7117

# YouVersion Platform — Bible verse detector in the reader.
# Tapping a reference like "John 3:16" inside a book opens a
# sheet that fetches the passage via the YV API. Mirrors the
# YVP_APP_KEY / YVP_DEFAULT_BIBLE_ID env vars on the mobile app.
NEXT_PUBLIC_YVP_APP_KEY=
NEXT_PUBLIC_YVP_DEFAULT_BIBLE_ID=3034
